# Build output
/dist/
/build/
/bin/
*.exe
*.dll
*.so
*.dylib

# Go
/core/vendor/
*.test
*.out

# Node / VS Code extension
node_modules/
*.vsix
.vscode-test/
out/
*.tsbuildinfo
# LICENSE and README are copied into the extension folder at package time
/adapters/vscode/LICENSE
/adapters/vscode/README.md
# Built core binaries are bundled into the .vsix at package time, never committed
/adapters/vscode/bin/

# JetBrains plugin (Gradle)
.gradle/
/adapters/jetbrains/build/

# Secrets / local fixtures — never commit a real token
*.credentials.json
.credentials.json
*.token
.env
.env.*
/fixtures/local/

# Claude / Agents hub — machine-specific junctions, not part of the project
.claude/

# OS
.DS_Store
Thumbs.db
desktop.ini
